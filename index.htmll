<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>داشبورد کریپتو</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Vazirmatn:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap');

  * { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #080b12;
    --surface: #0e1420;
    --card: #111827;
    --border: #1e2d45;
    --accent: #00d4ff;
    --accent2: #7c3aed;
    --green: #00e676;
    --red: #ff1744;
    --orange: #ff9100;
    --yellow: #ffd600;
    --text: #e2e8f0;
    --muted: #4a5568;
    --muted2: #718096;
  }

  body {
    font-family: 'Vazirmatn', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    direction: rtl;
  }

  /* Header */
  header {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: 14px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .logo-icon {
    width: 36px; height: 36px;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 16px;
  }

  .logo h1 {
    font-size: 16px;
    font-weight: 700;
    color: var(--text);
    font-family: 'Vazirmatn', sans-serif;
  }

  .logo p {
    font-size: 11px;
    color: var(--muted2);
  }

  .header-left {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .live-badge {
    display: flex;
    align-items: center;
    gap: 6px;
    background: rgba(0, 230, 118, 0.1);
    border: 1px solid rgba(0, 230, 118, 0.3);
    border-radius: 20px;
    padding: 4px 10px;
    font-size: 11px;
    color: var(--green);
    font-weight: 600;
  }

  .live-dot {
    width: 6px; height: 6px;
    background: var(--green);
    border-radius: 50%;
    animation: blink 1s infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.2; }
  }

  .countdown {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--muted2);
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 4px 10px;
  }

  /* Main */
  main { padding: 20px; max-width: 1400px; margin: 0 auto; }

  /* Settings Panel */
  .settings-panel {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 20px;
    margin-bottom: 20px;
  }

  .settings-title {
    font-size: 13px;
    font-weight: 700;
    color: var(--muted2);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .settings-row {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    align-items: flex-end;
  }

  .setting-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .setting-group label {
    font-size: 11px;
    color: var(--muted2);
    font-weight: 600;
  }

  .setting-group input {
    background: var(--card);
    border: 1.5px solid var(--border);
    border-radius: 8px;
    padding: 8px 12px;
    color: var(--text);
    font-size: 13px;
    font-family: 'JetBrains Mono', monospace;
    direction: ltr;
    outline: none;
    width: 140px;
    transition: border-color 0.2s;
  }

  .setting-group input:focus { border-color: var(--accent); }

  .add-btn {
    padding: 8px 18px;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    border: none;
    border-radius: 8px;
    color: white;
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
    font-family: 'Vazirmatn', sans-serif;
    transition: opacity 0.2s;
    white-space: nowrap;
  }

  .add-btn:hover { opacity: 0.85; }

  .symbols-list {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 14px;
  }

  .symbol-tag {
    display: flex;
    align-items: center;
    gap: 6px;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 5px 10px;
    font-size: 12px;
    font-family: 'JetBrains Mono', monospace;
    color: var(--accent);
    font-weight: 600;
  }

  .symbol-tag button {
    background: none;
    border: none;
    color: var(--muted2);
    cursor: pointer;
    font-size: 14px;
    line-height: 1;
    padding: 0;
    transition: color 0.2s;
  }

  .symbol-tag button:hover { color: var(--red); }

  /* EMA/RSI Config */
  .config-row {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 14px;
    padding-top: 14px;
    border-top: 1px solid var(--border);
  }

  .config-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    color: var(--muted2);
  }

  .config-item span { color: var(--text); font-weight: 600; }

  .config-item input {
    width: 60px;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 4px 8px;
    color: var(--text);
    font-size: 12px;
    font-family: 'JetBrains Mono', monospace;
    direction: ltr;
    text-align: center;
    outline: none;
  }

  .config-item input:focus { border-color: var(--accent); }

  /* Table */
  .table-wrap {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    direction: ltr;
  }

  thead {
    background: var(--card);
    border-bottom: 1px solid var(--border);
  }

  thead th {
    padding: 12px 16px;
    font-size: 11px;
    font-weight: 700;
    color: var(--muted2);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    text-align: left;
    white-space: nowrap;
  }

  thead th:first-child { text-align: left; }

  tbody tr {
    border-bottom: 1px solid var(--border);
    transition: background 0.15s;
  }

  tbody tr:last-child { border-bottom: none; }
  tbody tr:hover { background: rgba(255,255,255,0.02); }

  td {
    padding: 14px 16px;
    font-size: 13px;
    font-family: 'JetBrains Mono', monospace;
    text-align: left;
    white-space: nowrap;
  }

  .td-symbol {
    font-weight: 700;
    color: var(--text);
    font-size: 14px;
    font-family: 'JetBrains Mono', monospace;
  }

  .td-price { color: var(--text); font-weight: 600; }

  .td-ema { color: var(--muted2); }

  .dist-positive { color: var(--green); font-weight: 600; }
  .dist-negative { color: var(--red); font-weight: 600; }

  /* RSI badge */
  .rsi-badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 4px 10px;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 700;
  }

  .rsi-overbought {
    background: rgba(255, 23, 68, 0.12);
    border: 1px solid rgba(255, 23, 68, 0.3);
    color: var(--red);
  }

  .rsi-oversold {
    background: rgba(0, 230, 118, 0.12);
    border: 1px solid rgba(0, 230, 118, 0.3);
    color: var(--green);
  }

  .rsi-neutral {
    background: rgba(255,255,255,0.05);
    border: 1px solid var(--border);
    color: var(--muted2);
  }

  .rsi-warning-high {
    background: rgba(255, 145, 0, 0.12);
    border: 1px solid rgba(255, 145, 0, 0.3);
    color: var(--orange);
  }

  .rsi-warning-low {
    background: rgba(255, 214, 0, 0.12);
    border: 1px solid rgba(255, 214, 0, 0.3);
    color: var(--yellow);
  }

  /* Signal */
  .signal {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 4px 10px;
    border-radius: 6px;
    font-size: 11px;
    font-weight: 700;
    font-family: 'Vazirmatn', sans-serif;
  }

  .signal-buy { background: rgba(0,230,118,0.1); border: 1px solid rgba(0,230,118,0.3); color: var(--green); }
  .signal-sell { background: rgba(255,23,68,0.1); border: 1px solid rgba(255,23,68,0.3); color: var(--red); }
  .signal-none { background: rgba(255,255,255,0.04); border: 1px solid var(--border); color: var(--muted2); }

  /* Loading */
  .loading-row td {
    text-align: center;
    padding: 40px;
    color: var(--muted2);
    font-family: 'Vazirmatn', sans-serif;
  }

  .spinner {
    display: inline-block;
    width: 20px; height: 20px;
    border: 2px solid var(--border);
    border-top-color: var(--accent);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
    margin-left: 8px;
    vertical-align: middle;
  }

  @keyframes spin { to { transform: rotate(360deg); } }

  /* Alert banner */
  .alert-banner {
    background: rgba(255,23,68,0.08);
    border: 1px solid rgba(255,23,68,0.25);
    border-radius: 12px;
    padding: 12px 16px;
    margin-bottom: 16px;
    font-size: 13px;
    color: #ff6b8a;
    display: none;
    font-family: 'Vazirmatn', sans-serif;
    direction: rtl;
  }

  /* Error */
  .error-cell { color: var(--red); font-size: 11px; font-family: 'Vazirmatn', sans-serif; }

  /* Responsive */
  @media (max-width: 768px) {
    main { padding: 12px; }
    td, thead th { padding: 10px 10px; font-size: 11px; }
    .td-symbol { font-size: 12px; }
    .hide-mobile { display: none; }
  }
</style>
</head>
<body>

<header>
  <div class="logo">
    <div class="logo-icon">📊</div>
    <div>
      <h1>داشبورد فیوچرز</h1>
      <p>OKX Perpetual — EMA & RSI Monitor</p>
    </div>
  </div>
  <div class="header-left">
    <div class="countdown" id="countdown">⏱ 30s</div>
    <div class="live-badge"><div class="live-dot"></div>LIVE</div>
  </div>
</header>

<main>
  <!-- Alert -->
  <div class="alert-banner" id="alert-banner"></div>

  <!-- Settings -->
  <div class="settings-panel">
    <div class="settings-title">⚙️ تنظیمات</div>

    <div class="settings-row">
      <div class="setting-group">
        <label>نماد (مثال: SOLUSDT)</label>
        <input type="text" id="symbol-input" placeholder="SOLUSDT" style="text-transform:uppercase" />
      </div>
      <button class="add-btn" onclick="addSymbol()">+ اضافه کردن</button>
    </div>

    <div class="symbols-list" id="symbols-list"></div>

    <div class="config-row">
      <div class="config-item">
        <span>EMA دوره:</span>
        <input type="number" id="ema-period" value="9" min="1" max="200" onchange="refreshAll()" />
      </div>
      <div class="config-item">
        <span>EMA تایم‌فریم:</span>
        <select id="ema-tf" onchange="refreshAll()" style="background:var(--card);border:1px solid var(--border);border-radius:6px;padding:4px 8px;color:var(--text);font-size:12px;outline:none;direction:ltr;">
          <option value="1H" selected>1H</option>
          <option value="4H">4H</option>
          <option value="1D">1D</option>
          <option value="15m">15m</option>
          <option value="30m">30m</option>
        </select>
      </div>
      <div class="config-item">
        <span>RSI اشباع خرید:</span>
        <input type="number" id="rsi-ob" value="80" min="50" max="99" onchange="refreshAll()" />
      </div>
      <div class="config-item">
        <span>RSI اشباع فروش:</span>
        <input type="number" id="rsi-os" value="20" min="1" max="49" onchange="refreshAll()" />
      </div>
      <div class="config-item">
        <span>چارت تایم‌فریم:</span>
        <select id="chart-tf" onchange="refreshAll()" style="background:var(--card);border:1px solid var(--border);border-radius:6px;padding:4px 8px;color:var(--text);font-size:12px;outline:none;direction:ltr;">
          <option value="5m" selected>5m</option>
          <option value="15m">15m</option>
          <option value="1H">1H</option>
        </select>
      </div>
    </div>
  </div>

  <!-- Table -->
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>نماد</th>
          <th>قیمت فعلی</th>
          <th>EMA (<span id="th-ema">9</span> • <span id="th-tf">1H</span>)</th>
          <th>فاصله از EMA</th>
          <th>RSI (5m)</th>
          <th>سیگنال</th>
          <th>آپدیت</th>
        </tr>
      </thead>
      <tbody id="table-body">
        <tr class="loading-row">
          <td colspan="7">ابتدا یک نماد اضافه کنید <span class="spinner"></span></td>
        </tr>
      </tbody>
    </table>
  </div>
</main>

<script>
// State
let symbols = JSON.parse(localStorage.getItem('crypto-symbols') || '["BTCUSDT","ETHUSDT","SOLUSDT","BNBUSDT","XRPUSDT"]');
let intervalId = null;
let countdown = 30;
let countdownId = null;

// OKX instId converter
function toOKXInstId(symbol) {
  // SOLUSDT -> SOL-USDT-SWAP
  const base = symbol.replace('USDT', '');
  return `${base}-USDT-SWAP`;
}

// OKX timeframe converter
function toOKXBar(tf) {
  const map = { '1m':'1m','5m':'5m','15m':'15m','30m':'30m','1H':'1H','4H':'4H','1D':'1D' };
  return map[tf] || tf;
}

// Fetch OHLCV from OKX
async function fetchCandles(instId, bar, limit=100) {
  const url = `https://www.okx.com/api/v5/market/candles?instId=${instId}&bar=${bar}&limit=${limit}`;
  const res = await fetch(url);
  if (!res.ok) throw new Error('OKX API error');
  const data = await res.json();
  if (data.code !== '0') throw new Error(data.msg || 'OKX error');
  // Returns: [ts, open, high, low, close, vol, volCcy, volCcyQuote, confirm]
  return data.data.reverse(); // oldest first
}

// Fetch ticker (current price)
async function fetchTicker(instId) {
  const url = `https://www.okx.com/api/v5/market/ticker?instId=${instId}`;
  const res = await fetch(url);
  const data = await res.json();
  if (data.code !== '0') throw new Error(data.msg);
  return parseFloat(data.data[0].last);
}

// Calculate EMA
function calcEMA(closes, period) {
  if (closes.length < period) return null;
  const k = 2 / (period + 1);
  let ema = closes.slice(0, period).reduce((a,b) => a+b, 0) / period;
  for (let i = period; i < closes.length; i++) {
    ema = closes[i] * k + ema * (1 - k);
  }
  return ema;
}

// Calculate RSI
function calcRSI(closes, period=14) {
  if (closes.length < period + 1) return null;
  let gains = 0, losses = 0;
  for (let i = closes.length - period; i < closes.length; i++) {
    const diff = closes[i] - closes[i-1];
    if (diff > 0) gains += diff;
    else losses += Math.abs(diff);
  }
  const avgGain = gains / period;
  const avgLoss = losses / period;
  if (avgLoss === 0) return 100;
  const rs = avgGain / avgLoss;
  return 100 - (100 / (1 + rs));
}

// Fetch all data for one symbol
async function fetchSymbolData(symbol) {
  const instId = toOKXInstId(symbol);
  const emaTF = toOKXBar(document.getElementById('ema-tf').value);
  const chartTF = toOKXBar(document.getElementById('chart-tf').value);
  const emaPeriod = parseInt(document.getElementById('ema-period').value) || 9;

  const [emaCandles, rsiCandles, price] = await Promise.all([
    fetchCandles(instId, emaTF, Math.max(emaPeriod * 3, 100)),
    fetchCandles(instId, chartTF, 50),
    fetchTicker(instId)
  ]);

  const emaCloses = emaCandles.map(c => parseFloat(c[4]));
  const rsiCloses = rsiCandles.map(c => parseFloat(c[4]));

  const ema = calcEMA(emaCloses, emaPeriod);
  const rsi = calcRSI(rsiCloses, 14);

  return { price, ema, rsi };
}

// Render table
function renderTable() {
  const tbody = document.getElementById('table-body');
  if (symbols.length === 0) {
    tbody.innerHTML = '<tr class="loading-row"><td colspan="7">هیچ نمادی اضافه نشده — یک نماد اضافه کنید</td></tr>';
    return;
  }
  tbody.innerHTML = symbols.map(s => `
    <tr id="row-${s}">
      <td class="td-symbol">${s}</td>
      <td colspan="6" class="loading-row" style="color:var(--muted2);font-family:'Vazirmatn',sans-serif;">
        <span class="spinner"></span> در حال بارگذاری...
      </td>
    </tr>
  `).join('');
}

// Update one row
async function updateRow(symbol) {
  const row = document.getElementById(`row-${symbol}`);
  if (!row) return;

  try {
    const { price, ema, rsi } = await fetchSymbolData(symbol);
    const emaPeriod = document.getElementById('ema-period').value;
    const emaTF = document.getElementById('ema-tf').value;
    const rsiOB = parseFloat(document.getElementById('rsi-ob').value) || 80;
    const rsiOS = parseFloat(document.getElementById('rsi-os').value) || 20;
    const chartTF = document.getElementById('chart-tf').value;

    const distPct = ema ? ((price - ema) / ema * 100) : null;
    const distClass = distPct >= 0 ? 'dist-positive' : 'dist-negative';
    const distSign = distPct >= 0 ? '+' : '';

    // RSI class
    let rsiClass = 'rsi-neutral', rsiLabel = '';
    if (rsi !== null) {
      if (rsi >= rsiOB) { rsiClass = 'rsi-overbought'; rsiLabel = '🔴 اشباع خرید'; }
      else if (rsi <= rsiOS) { rsiClass = 'rsi-oversold'; rsiLabel = '🟢 اشباع فروش'; }
      else if (rsi >= rsiOB - 5) { rsiClass = 'rsi-warning-high'; rsiLabel = '⚠️ نزدیک اشباع'; }
      else if (rsi <= rsiOS + 5) { rsiClass = 'rsi-warning-low'; rsiLabel = '⚠️ نزدیک اشباع'; }
      else rsiLabel = '—';
    }

    // Signal
    let signalHTML = '<span class="signal signal-none">—</span>';
    if (rsi !== null && ema !== null) {
      if (rsi >= rsiOB) signalHTML = '<span class="signal signal-sell">🔴 فروش</span>';
      else if (rsi <= rsiOS) signalHTML = '<span class="signal signal-buy">🟢 خرید</span>';
    }

    const now = new Date().toLocaleTimeString('fa-IR');

    row.innerHTML = `
      <td class="td-symbol">${symbol}</td>
      <td class="td-price">$${price.toLocaleString('en-US', {minimumFractionDigits:2, maximumFractionDigits:4})}</td>
      <td class="td-ema">${ema ? '$' + ema.toLocaleString('en-US', {minimumFractionDigits:2, maximumFractionDigits:4}) : '—'}</td>
      <td class="${distClass}">${distPct !== null ? distSign + distPct.toFixed(2) + '%' : '—'}</td>
      <td><span class="rsi-badge ${rsiClass}">${rsi !== null ? rsi.toFixed(1) : '—'} ${rsiLabel}</span></td>
      <td>${signalHTML}</td>
      <td style="color:var(--muted2);font-size:11px;">${now}</td>
    `;

    // Show alert if RSI signal
    if (rsi !== null && (rsi >= rsiOB || rsi <= rsiOS)) {
      showAlert(symbol, rsi, rsiOB, rsiOS);
    }

  } catch(err) {
    row.innerHTML = `
      <td class="td-symbol">${symbol}</td>
      <td colspan="6" class="error-cell">⚠️ خطا در دریافت داده — ${err.message}</td>
    `;
  }
}

let alerts = {};
function showAlert(symbol, rsi, ob, os) {
  const key = symbol + (rsi >= ob ? '_ob' : '_os');
  if (alerts[key]) return;
  alerts[key] = true;
  setTimeout(() => delete alerts[key], 120000);

  const banner = document.getElementById('alert-banner');
  const type = rsi >= ob ? `اشباع خرید (${rsi.toFixed(1)})` : `اشباع فروش (${rsi.toFixed(1)})`;
  banner.style.display = 'block';
  banner.innerHTML = `🚨 <strong>${symbol}</strong> — RSI به منطقه ${type} رسید!`;
  setTimeout(() => { banner.style.display = 'none'; }, 10000);
}

async function refreshAll() {
  document.getElementById('th-ema').textContent = document.getElementById('ema-period').value;
  document.getElementById('th-tf').textContent = document.getElementById('ema-tf').value;
  renderTable();
  for (const s of symbols) {
    await updateRow(s);
  }
}

function addSymbol() {
  const input = document.getElementById('symbol-input');
  let val = input.value.trim().toUpperCase();
  if (!val) return;
  if (!val.endsWith('USDT')) val += 'USDT';
  if (symbols.includes(val)) { input.value = ''; return; }
  symbols.push(val);
  saveSymbols();
  input.value = '';
  renderTable();
  updateRow(val);
  renderTags();
}

function removeSymbol(symbol) {
  symbols = symbols.filter(s => s !== symbol);
  saveSymbols();
  renderTags();
  renderTable();
}

function saveSymbols() {
  localStorage.setItem('crypto-symbols', JSON.stringify(symbols));
}

function renderTags() {
  const list = document.getElementById('symbols-list');
  list.innerHTML = symbols.map(s => `
    <div class="symbol-tag">
      ${s}
      <button onclick="removeSymbol('${s}')" title="حذف">×</button>
    </div>
  `).join('');
}

function startCountdown() {
  countdown = 30;
  clearInterval(countdownId);
  countdownId = setInterval(() => {
    countdown--;
    document.getElementById('countdown').textContent = `⏱ ${countdown}s`;
    if (countdown <= 0) {
      countdown = 30;
      refreshAll();
    }
  }, 1000);
}

// Symbol input enter key
document.getElementById('symbol-input').addEventListener('keydown', e => {
  if (e.key === 'Enter') addSymbol();
});

// Init
renderTags();
renderTable();
if (symbols.length > 0) refreshAll();
startCountdown();
clearInterval(intervalId);
intervalId = setInterval(refreshAll, 30000);
</script>
</body>
</html>
